{
  "name": "techtool-app-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --include server/**/*.ts --include shared/**/*.ts server/server.ts",
    "build": "vite build && tsc -p tsconfig.server.json && tsc-alias -p tsconfig.server.json",
    "start": "node dist-backend/server/server.js",
    "audit:contrast": "node scripts/contrast-audit.js",
    "check:boundaries": "node scripts/check-runtime-boundaries.js",
    "check:migrations": "node scripts/check-migration-order.js",
    "lint": "eslint --config eslint.config.js src server shared --ext .ts,.tsx",
    "ci": "npm run lint && npm run check:boundaries && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db": "node scripts/test-connection.js",
    "backup:db": "node scripts/backup-database.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^3.10.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.39.0",
    "@tanstack/react-query": "^5.17.0",
    "@tiptap/extension-link": "^3.15.3",
    "@tiptap/extension-table": "^3.15.3",
    "@tiptap/extension-table-cell": "^3.15.3",
    "@tiptap/extension-table-header": "^3.15.3",
    "@tiptap/extension-table-row": "^3.15.3",
    "@tiptap/extension-task-item": "^3.20.1",
    "@tiptap/extension-task-list": "^3.20.1",
    "@tiptap/extension-underline": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cookie": "^1.0.2",
    "date-fns": "^3.0.0",
    "express": "^4.21.2",
    "postgres": "^3.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.66.1",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.7.0",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.5",
    "typescript": "^5.3.0",
    "vite": "^6.3.6",
    "vitest": "^4.0.18"
  }
}
